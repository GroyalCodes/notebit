# Copy to .env and adjust. All values are optional except APP_URL for invite emails.

# Port the server listens on (default 8200)
PORT=8200

# Where the SQLite database lives (default ./data/notebit.db; /data/notebit.db in Docker)
# WIKI_DB=/data/notebit.db

# Public URL people use to reach this instance (used in invitation emails)
APP_URL=http://localhost:8200

# Email invites (optional) — get a key at https://resend.com
# RESEND_API_KEY=re_xxxxxxxx
# MAIL_FROM=NoteBit <you@yourdomain.com>

# Set to false to close public sign-ups (invite-only)
# ALLOW_SIGNUP=true
